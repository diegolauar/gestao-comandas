{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@domain/*":       ["src/domain/*"],
      "@application/*":  ["src/application/*"],
      "@infra/*":        ["src/infrastructure/*"],
      "@presentation/*": ["src/presentation/*"],
      "@assets/*":       ["assets/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": ["src"]
}
